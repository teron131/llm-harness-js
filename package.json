{
	"name": "llm-harness-js",
	"version": "0.1.0",
	"description": "TypeScript harness for tools, agents, and model stats workflows",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./agents": {
			"types": "./dist/agents/index.d.ts",
			"import": "./dist/agents/index.js"
		},
		"./clients": {
			"types": "./dist/clients/index.d.ts",
			"import": "./dist/clients/index.js"
		},
		"./tools": {
			"types": "./dist/tools/index.d.ts",
			"import": "./dist/tools/index.js"
		},
		"./tools/web": {
			"types": "./dist/tools/web/index.d.ts",
			"import": "./dist/tools/web/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"engines": {
		"node": ">=20"
	},
	"packageManager": "bun@1.2.21",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"aa:stats": "bun ./scripts/run-aa-stats.mjs",
		"image:reference": "bun ./scripts/run-image-stats-reference.mjs",
		"stats:table": "bun ./scripts/test-stats.mjs",
		"stats:parity": "bun ./scripts/run-stats-parity-snapshot.mjs",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"format": "git ls-files -z -- '*.js' '*.jsx' '*.ts' '*.tsx' '*.json' '*.jsonc' | xargs -0 biome format --write",
		"format:check": "git ls-files -z -- '*.js' '*.jsx' '*.ts' '*.tsx' '*.json' '*.jsonc' | xargs -0 biome format",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"dev": "bun --watch src/index.ts"
	},
	"dependencies": {
		"@google/genai": "^1.48.0",
		"@langchain/core": "^1.1.39",
		"@langchain/google-genai": "^2.1.26",
		"@langchain/langgraph": "^1.2.8",
		"@langchain/openai": "^1.4.3",
		"@mariozechner/pi-agent-core": "^0.65.2",
		"@mariozechner/pi-ai": "^0.65.2",
		"@mariozechner/pi-coding-agent": "^0.65.2",
		"exa-js": "^2.11.0",
		"langchain": "^1.3.1",
		"mathjs": "^15.2.0",
		"opencc-js": "^1.0.5",
		"sharp": "^0.34.5",
		"turndown": "^7.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.2",
		"eslint": "^10.2.0",
		"globals": "^17.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vitest": "^4.1.3"
	}
}
